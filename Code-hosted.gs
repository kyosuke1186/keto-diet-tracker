table-wrap {\n      overflow-x: auto;\n      max-height: 460px;\n    }\n\n    table {\n      width: 100%;\n      min-width: 640px;\n      border-collapse: collapse;\n      font-size: 13px;\n    }\n\n    th, td {\n      border-bottom: 1px solid var(--line);\n      padding: 9px 10px;\n      text-align: left;\n      vertical-align: top;\n    }\n\n    th {\n      position: sticky;\n      top: 0;\n      z-index: 1;\n      color: var(--muted);\n      background: #f8faf6;\n      font-size: 12px;\n    }\n\n    .num {\n      text-align: right;\n      white-space: nowrap;\n    }\n\n    .good { color: var(--green); }\n    .warn { color: var(--amber); }\n    .bad { color: var(--red); }\n    .blue { color: var(--blue); }\n\n    .empty {\n      border: 1px dashed var(--line);\n      border-radius: 8px;\n      padding: 24px 12px;\n      color: var(--muted);\n      text-align: center;\n      background: #fbfcfa;\n    }\n\n    .toast {\n      position: fixed;\n      left: 50%;\n      bottom: 18px;\n      z-index: 20;\n      transform: translateX(-50%) translateY(16px);\n      opacity: 0;\n      pointer-events: none;\n      border-radius: 8px;\n      padding: 10px 14px;\n      color: #fff;\n      background: var(--ink);\n      box-shadow: var(--shadow);\n      transition: opacity 0.18s ease, transform 0.18s ease;\n    }\n\n    .toast.show {\n      opacity: 1;\n      transform: translateX(-50%) translateY(0);\n    }\n\n    @media (max-width: 1040px) {\n      .app {\n        height: auto;\n        grid-template-columns: 1fr;\n      }\n\n      aside {\n        position: static;\n        height: auto;\n        overflow: visible;\n        border-right: 0;\n        border-bottom: 1px solid var(--line);\n      }\n\n      main {\n        height: auto;\n        overflow: visible;\n      }\n\n      .content-grid,\n      .hero {\n        grid-template-columns: 1fr;\n      }\n\n      .metric-grid {\n        grid-template-columns: repeat(2, minmax(0, 1fr));\n      }\n    }\n\n    @media (max-widt