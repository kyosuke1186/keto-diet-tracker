d=\"syncStatusLabel\">未設定</strong>\n            <span id=\"syncStatusDetail\">Googleスプレッドシートと連動します。</span>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"panel\">\n        <div class=\"panel-head\">\n          <h3>データ</h3>\n        </div>\n        <div class=\"panel-body\">\n          <div class=\"btn-row\">\n            <button id=\"exportBtn\" class=\"btn btn-ghost\" type=\"button\">JSON出力</button>\n            <label class=\"btn btn-ghost\">JSON読込<input id=\"importInput\" type=\"file\" accept=\"application/json,.json\" hidden></label>\n          </div>\n          <button id=\"clearBtn\" class=\"btn btn-danger\" type=\"button\">全削除</button>\n          <p class=\"mini-note\">保存はこの端末とGoogleスプレッドシートに反映します。</p>\n        </div>\n      </section>\n    </aside>\n\n    <main>\n      <section class=\"hero\">\n        <div class=\"current-block\">\n          <div class=\"current-label\">現在の体重</div>\n          <div id=\"currentWeight\" class=\"current-number\">--<small>kg</small></div>\n          <div id=\"statusPill\" class=\"status-pill\">まだ記録がありません</div>\n          <p id=\"goalNote\" class=\"mini-note\"></p>\n        </div>\n        <div class=\"current-block\">\n          <div class=\"current-label\">目標までの進み具合</div>\n          <div class=\"meter\"><div id=\"goalMeter\" class=\"meter-fill\"></div></div>\n          <div class=\"grid-2\">\n            <div>\n              <div class=\"mini-note\">開始</div>\n              <strong id=\"startWeightLabel\">85.0kg</strong>\n            </div>\n            <div>\n              <div class=\"mini-note\">目標</div>\n              <strong id=\"goalWeightLabel\">70.0kg</strong>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"metric-grid\">\n        <div class=\"metric-card\">\n          <span>開始から</span>\n          <strong id=\"lostFromStart\">--kg</strong>\n        </div>\n        <div class=\"metric-card\">\n          <span>目標まで</span>\n          <strong id=\"toGoalWeight\">--kg</strong>\n        </div>\n        <div class=\"metric-card\">\n          <span>7日平均</span>\n          <strong id=\"avg7Weight\">--kg</strong>\n        </div>\n        <div class=\"metric-card\">\n          <span>今週の変化</span>\n          <strong id=\"weekChange\">--kg</strong>\n        </div>\n      </section>\n\n      <section class=\"content-grid\">\n        <section class=\"panel\">\n          <div class=\"panel-head\">\n            <h2>体重推移</h2>\n            <div class=\"range-control\">\n              <button type=\"button\" data-range=\"7\">7日</button>\n              <button type=\"button\" data-range=\"30\" class=\"active\">30日</button>\n              <button type=\"button\" data-range=\"all\">全期間</button>\n            </div>\n          </div>\n          <div class=\"panel-body\">\n            <div class=\"chart-wrap\">\n              <canvas id=\"weightChart\"></canvas>\n            </div>\n            <p class=\"mini-note\">線: 体重 / 薄線: 7日平均 / 点線: 目標体重</p>\n          </div>\n        </section>\n\n        <section class=\"panel\">\n          <div class=\"panel-head\">\n            <h2>記録一覧</h2>\n            <span id=\"recordCount\" class=\"mini-note\"></span>\n          </div>\n          <div class=\"table-wrap\">\n            <table>\n              <thead>\n                <tr>\n                  <th>日付</th>\n                  <th>朝</th>\n                  <th>夜</th>\n                  <th>表示体重</th>\n                  <th>前日差</th>\n                  <th>メモ</th>\n                  <th></th>\n                </tr>\n              </thead>\n              <tbody id=\"recordTable\"></tbody>\n            </table>\n          </div>\n        </section>\n      </section>\n    </main>\n  </div>\n\n  <div id=\"toast\" class=\"toast\"></div>\n\n  <script>\n    const STORAGE_KEY = \"weight-tracker-app-v1\";\n    const SYNC_STORAGE_KEY = \"weight-tracker-sync-v1\";\n    const SLOT_LABELS = { morning: \"朝\", evening: \"夜\" };\n    const RANGE_DAYS = { \"7\": 7, \"30\": 30, all: null };\n\n    const state = {\n      settings: {\n        height: 174,\n        startWeight: 85,\n        goalWeight: 70,\n        displaySlot: \"morning\"\n      },\n      weights: [],\n      range: \"30\",\n      sync: {\n        url: \"\",\n        token: \"\",\n        lastPulledAt: \"\",\n        lastPushedAt: \"\",\n        pending: false\n      }\n    };\n\n    const el = {\n      weightDate: document.getElementById(\"weightDateInput\"),\n      weightSlot: document.getElementById(\"weightSlotInput\"),\n      weight: document.getElementById(\"weightInput\"),\n      note: document.getElementById(\"noteInput\"),\n      saveWeight: document.getElementById(\"saveWeightBtn\"),\n      height: document.getElementById(\"heightInput\"),\n      startWeight: document.getElementById(\"startWeightInput\"),\n      goalWeight: document.getElementById(\"goalWeightInput\"),\n      displaySlot: document.getElementById(\"displaySlotInput\"),\n      saveSettings: document.getElementById(\"saveSettingsBtn\"),\n      currentWeight: document.getElementById(\"currentWeight\"),\n      statusPill: document.getElementById(\"statusPill\"),\n      goalNote: document.getElementById(\"goalNote\"),\n      goalMeter: document.getElementById(\"goalMeter\"),\n      startWeightLabel: document.getElementById(\"startWeightLabel\"),\n      goalWeightLabel: document.getElementById(\"goalWeightLabel\"),\n      lostFromStart: document.getElementById(\"lostFromStart\"),\n      toGoalWeight: document.getElementById(\"toGoalWeight\"),\n      avg7Weight: document.getElementById(\"avg7Weight\"),\n      weekChange: document.getElementById(\"weekChange\"),\n      weightChart: document.getElementById(\"weightChart\"),\n      recordTable: document.getElementById(\"recordTable\"),\n      recordCount: document.getElementById(\"recordCount\"),\n      syncUrl: document.getElementById(\"syncUrlInput\"),\n      syncToken: document.getElementById(\"syncTokenInput\"),\n      saveSync: document.getElementById(\"saveSyncBtn\"),\n      pullSync: document.getElementById(\"pullSyncBtn\"),\n      pushSync: document.getElementById(\"pushSyncBtn\"),\n      syncStatusLabel: document.getElementById(\"syncStatusLabel\"),\n      syncStatusDetail: document.getElementById(\"syncStatusDetail\"),\n      exportBtn: document.getElementById(\"exportBtn\"),\n      importInput: document.getElementById(\"importInput\"),\n      clearBtn: document.getElementById(\"clearBtn\"),\n      toast: document.getElementById(\"toast\")\n    };\n\n    function todayIso() {\n      const now = new Date();\n      now.setMinutes(now.getMinutes() - now.getTimezoneOffset());\n      return now.toISOString().slice(0, 10);\n    }\n\n    function load() {\n      try {\n        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || \"{}\");\n        Object.assign(state.settings, saved.settings || {});\n        state.weights = Array.isArray(saved.weights) ? saved.weights : [];\n      } catch {\n        state.weights = [];\n      }\n\n      try {\n        Object.assign(state.sync, JSON.parse(localStorage.getItem(SYNC_STORAGE_KEY) || \"{}\"));\n      } catch {\n        state.sync = { url: \"\", token: \"\", lastPulledAt: \"\", lastPushedAt: \"\", pending: false };\n      }\n\n      el.weightDate.value = todayIso();\n      el.weightSlot.value = \"morning\";\n      syncSettingsInputs();\n      renderSyncStatus();\n    }\n\n    function syncSettingsInputs() {\n      el.height.value = state.settings.height;\n      el.startWeight.value = state.settings.startWeight;\n      el.goalWeight.value = state.settings.goalWeight;\n      el.displaySlot.value = state.settings.displaySlot || \"morning\";\n      el.syncUrl.value = state.sync.url || \"\";\n      el.syncToken.value = state.sync.token || \"\";\n    }\n\n    function save() {\n      saveLocalOnly();\n      queueAutoSync();\n    }\n\n    function saveLocalOnly() {\n      localStorage.setItem(STORAGE_KEY, JSON.stringify(getAppData()));\n      localStorage.setItem(SYNC_STORAGE_KEY, JSON.stringify(state.sync));\n    }\n\n    function getAppData() {\n      return {\n        settings: state.settings,\n        weights: state.weights\n      };\n    }\n\n    function applyAppData(data) {\n      Object.assign(state.settings, data.settings || {});\n      state.weights = Array.isArray(data.weights) ? data.weights : [];\n      syncSettingsInputs();\n      saveLocalOnly();\n      render();\n    }\n\n    function mergeRecordLists(primary = [], secondary = []) {\n      const records = new Map();\n      const put = (record) => {\n        if (!record || !record.id) return;\n        const existing = records.get(record.id);\n        if (!existing) {\n          records.set(record.id, record);\n          return;\n        }\n        const existingTime = Date.parse(existing.updatedAt || existing.createdAt || \"\") || 0;\n        const recordTime = Date.parse(record.updatedAt || record.createdAt || \"\") || 0;\n        if (recordTime >= existingTime) records.set(record.id, record);\n      };\n      primary.forEach(put);\n      secondary.forEach(put);\n      return Array.from(records.values()).sort((a, b) => String(a.date || \"\").localeCompare(String(b.date || \"\")));\n    }\n\n    function mergeAppData(remoteData = {}) {\n      const localData = getAppData();\n      return {\n        settings: {\n          ...localData.settings,\n          ...(remoteData.settings || {})\n        },\n        weights: mergeRecordLists(remoteData.weights || [], localData.weights || [])\n      };\n    }\n\n    function renderSyncStatus() {\n      if (!state.sync.url) {\n        el.syncStatusLabel.textContent = \"自動同期\";\n        el.syncStatusDetail.textContent = \"Googleスプレッドシートと連動します。\";\n        return;\n      }\n      const pushed = state.sync.lastPushedAt ? new Date(state.sync.lastPushedAt).toLocaleString(\"ja-JP\") : \"未実行\";\n      const pulled = state.sync.lastPulledAt ? new Date(state.sync.lastPulledAt).toLocaleString(\"ja-JP\") : \"未実行\";\n      el.syncStatusLabel.textContent = state.sync.pending ? \"同期中\" : \"同期設定済み\";\n      el.syncStatusDetail.textContent = `最終同期: 送信 ${pushed} / 読込 ${pulled}`;\n    }\n\n    function syncUrl() {\n      return \"hosted\";\n    }\n\n    function syncToken() {\n      return \"\";\n    }\n\n    function queueAutoSync() {\n      window.clearTimeout(queueAutoSync.timer);\n      queueAutoSync.timer = window.setTimeout(() => pushSync(true), 900);\n    }\n\n    function jsonp() {\n      return Promise.reject(new Error(\"この版では使いません\"));\n    }\n\n    async function pullSync() {\n      state.sync.pending = true;\n      renderSyncStatus();\n      try {\n        const data = await new Promise((resolve, reject) => {\n          google.script.run\n            .withSuccessHandler(resolve)\n            .withFailureHandler(reject)\n            .loadDataForClient();\n        });\n        applyAppData(mergeAppData(data || {}));\n        state.sync.lastPulledAt = new Date().toISOString();\n        state.sync.pending = false;\n        saveLocalOnly();\n        renderSyncStatus();\n        pushSync(true);\n        showToast(\"Googleから読み込みました\");\n      } catch (error) {\n        state.sync.pending = false;\n        saveLocalOnly();\n        renderSyncStatus();\n        showToast(error && error.message ? error.message : \"同期できませんでした\");\n      }\n    }\n\n    async function pushSync(silent = false) {\n      state.sync.pending = true;\n      renderSyncStatus();\n      try {\n        await new Promise((resolve, reject) => {\n          google.script.run\n            .withSuccessHandler(resolve)\n            .withFailureHandler(reject)\n            .saveDataForClient(getAppData());\n        });\n        state.sync.lastPushedAt = new Date().toISOString();\n        state.sync.pending = false;\n        saveLocalOnly();\n        renderSyncStatus();\n        if (!silent) showToast(\"Googleへ同期しました\");\n      } catch (error) {\n        state.sync.pending = false;\n        saveLocalOnly();\n        renderSyncStatus();\n        if (!silent) showToast(error && error.message ? error.message : \"Googleへ同期できませんでした\");\n      }\n    }\n\n    function showToast(message) {\n      el.toast.textContent = message;\n      el.toast.classList.add(\"show\");\n      window.clearTimeout(showToast.timer);\n      showToast.timer = window.setTimeout(() => el.toast.classList.remove(\"show\"), 1800);\n    }\n\n    function numberOrNull(value) {\n      const number = Number(value);\n      return Number.isFinite(number) && number > 0 ? number : null;\n    }\n\n    function round(value, digits = 1) {\n      const scale = 10 ** digits;\n      return Math.round((Number(value) || 0) * scale) / scale;\n    }\n\n    function signed(value) {\n      if (value === null || value === undefined || !Number.isFinite(value)) return \"--kg\";\n      return `${value > 0 ? \"+\" : \"\"}${value.toFixed(1)}kg`;\n    }\n\n    function formatDate(iso) {\n      const date = new Date(`${iso}T00:00:00`);\n      return date.toLocaleDateString(\"ja-JP\", { month: \"numeric\", day: \"numeric\", weekday: \"short\" });\n    }\n\n    function dateShift(iso, days) {\n      const date = new Date(`${iso}T00:00:00`);\n      date.setDate(date.getDate() + days);\n      date.setMinutes(date.getMinutes() - date.getTimezoneOffset());\n      return date.toISOString().slice(0, 10);\n    }\n\n    function dailyRows() {\n      const rows = new Map();\n      state.weights.forEach((entry) => {\n        if (!entry.date) return;\n        if (!rows.has(entry.date)) rows.set(entry.date, { date: entry.date, morning: null, evening: null, notes: [] });\n        const row = rows.get(entry.date);\n        if (entry.slot === \"evening\") row.evening = entry;\n        else row.morning = entry;\n        if (entry.note) row.notes.push(entry.note);\n      });\n\n      return Array.from(rows.values())\n        .sort((a, b) => a.date.localeCompare(b.date))\n        .map((row) => {\n          row.displayWeight = displayWeightForRow(row);\n          return row;\n        })\n        .filter((row) => row.displayWeight);\n    }\n\n    function displayWeightForRow(row) {\n      const mode = state.settings.displaySlot || \"morning\";\n      const morning = row.morning ? Number(row.morning.weight) : null;\n      const evening = row.evening ? Number(row.evening.weight) : null;\n      if (mode === \"average\" && morning && evening) return { weight: round((morning + evening) / 2), source: \"平均\" };\n      if (mode === \"evening\") {\n        if (evening) return { weight: evening, source: \"夜\" };\n        if (morning) return { weight: morning, source: \"朝\" };\n      }\n      if (morning) return { weight: morning, source: \"朝\" };\n      if (evening) return { weight: evening, source: \"夜\" };\n      return null;\n    }\n\n    function visibleRows() {\n      const rows = dailyRows();\n      const days = RANGE_DAYS[state.range];\n      if (!days || rows.length <= days) return rows;\n      return rows.slice(-days);\n    }\n\n    function movingAverage(rows, index, windowSize = 7) {\n      const start = Math.max(0, index - windowSize + 1);\n      const subset = rows.slice(start, index + 1).map((row) => row.displayWeight.weight);\n      if (!subset.length) return null;\n      return subset.reduce((sum, value) => sum + value, 0) / subset.length;\n    }\n\n    function latestRow() {\n      const rows = dailyRows();\n      return rows.length ? rows[rows.length - 1] : null;\n    }\n\n    function averageSince(days) {\n      const rows = dailyRows();\n      const latest = latestRow();\n      if (!latest) return null;\n      const from = dateShift(latest.date, -days + 1);\n      const values = rows.filter((row) => row.date >= from).map((row) => row.displayWeight.weight);\n      if (!values.length) return null;\n      return values.reduce((sum, value) => sum + value, 0) / values.length;\n    }\n\n    function render() {\n      renderSummary();\n      renderTable();\n      drawWeightChart();\n    }\n\n    function renderSummary() {\n      const latest = latestRow();\n      const start = Number(state.settings.startWeight) || 85;\n      const goal = Number(state.settings.goalWeight) || 70;\n      const heightM = (Number(state.settings.height) || 174) / 100;\n      const avg7 = averageSince(7);\n      const rows = dailyRows();\n      const weekAgo = latest ? rows.filter((row) => row.date <= dateShift(latest.date, -7)).pop() : null;\n\n      el.startWeightLabel.textContent = `${start.toFixed(1)}kg`;\n      el.goalWeightLabel.textContent = `${goal.toFixed(1)}kg`;\n\n      if (!latest) {\n        el.currentWeight.innerHTML = `--<small>kg</small>`;\n        el.statusPill.textContent = \"まだ記録がありません\";\n        el.goalNote.textContent = \"最初の体重を入力すると推移が見えるようになります。\";\n        el.goalMeter.style.width = \"0%\";\n        el.lostFromStart.textContent = \"--kg\";\n        el.toGoalWeight.textContent = \"--kg\";\n        el.avg7Weight.textContent = \"--kg\";\n        el.weekChange.textContent = \"--kg\";\n        return;\n      }\n\n      const current = latest.displayWeight.weight;\n      const lost = current - start;\n      const remaining = Math.max(0, current - goal);\n      const totalTarget = Math.max(0.1, start - goal);\n      const progress = Math.max(0, Math.min(100, ((start - current) / totalTarget) * 100));\n      const bmi = heightM ? current / (heightM * heightM) : null;\n      const weekDiff = weekAgo ? current - weekAgo.displayWeight.weight : null;\n\n      el.currentWeight.innerHTML = `${current.toFixed(1)}<small>kg</small>`;\n      el.statusPill.textContent = `${formatDate(latest.date)} ${latest.displayWeight.source}の記録`;\n      el.goalNote.textContent = `BMI ${bmi ? bmi.toFixed(1) : \"--\"} / 目標まで あと${remaining.toFixed(1)}kg`;\n      el.goalMeter.style.width = `${progress}%`;\n      el.lostFromStart.textContent = signed(lost);\n      el.lostFromStart.className = lost <= 0 ? \"good\" : \"warn\";\n      el.toGoalWeight.textContent = `あと ${remaining.toFixed(1)}kg`;\n      el.avg7Weight.textContent = avg7 ? `${avg7.toFixed(1)}kg` : \"--kg\";\n      el.weekChange.textContent = weekDiff === null ? \"--kg\" : signed(weekDiff);\n      el.weekChange.className = weekDiff === null ? \"\" : weekDiff <= 0 ? \"good\" : \"warn\";\n    }\n\n    function renderTable() {\n      const rows = dailyRows().slice().reverse();\n      el.recordCount.textContent = `${state.weights.length}件`;\n      if (!rows.length) {\n        el.recordTable.innerHTML = `<tr><td colspan=\"7\"><div class=\"empty\">体重を保存するとここに表示されます。</div></td></tr>`;\n        return;\n      }\n\n      el.recordTable.innerHTML = rows.map((row, index) => {\n        const previous = rows[index + 1];\n        const diff = previous ? row.displayWeight.weight - previous.displayWeight.weight : null;\n        const notes = Array.from(new Set(row.notes.filter(Boolean))).join(\" / \");\n        return `\n          <tr>\n            <td>${formatDate(row.date)}</td>\n            <td class=\"num\">${row.morning ? row.morning.weight.toFixed(1) : \"--\"}</td>\n            <td class=\"num\">${row.evening ? row.evening.weight.toFixed(1) : \"--\"}</td>\n            <td class=\"num\">${row.displayWeight.weight.toFixed(1)}kg</td>\n            <td class=\"num ${diff === null ? \"\" : diff <= 0 ? \"good\" : \"warn\"}\">${diff === null ? \"--\" : signed(diff)}</td>\n            <td>${escapeHtml(notes || \"\")}</td>\n            <td class=\"num\"><button class=\"btn btn-ghost\" type=\"button\" data-edit-date=\"${row.date}\">編集</button></td>\n          </tr>\n        `;\n      }).join(\"\");\n    }\n\n    function drawWeightChart() {\n      const canvas = el.weightChart;\n      const ctx = canvas.getContext(\"2d\");\n      const ratio = window.devicePixelRatio || 1;\n      const rect = canvas.getBoundingClientRect();\n      canvas.width = Math.max(1, Math.floor(rect.width * ratio));\n      canvas.height = Math.max(1, Math.floor(rect.height * ratio));\n      ctx.setTransform(ratio, 0, 0, ratio, 0, 0);\n\n      const width = rect.width;\n      const height = rect.height;\n      ctx.clearRect(0, 0, width, height);\n\n      const rows = visibleRows();\n      if (!rows.length) {\n        ctx.fillStyle = \"#687577\";\n        ctx.font = \"700 14px -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif\";\n        ctx.textAlign = \"center\";\n        ctx.fillText(\"体重を記録するとグラフが表示されます\", width / 2, height / 2);\n        return;\n      }\n\n      const pad = { top: 24, right: 18, bottom: 48, left: 48 };\n      const chartW = width - pad.left - pad.right;\n      const chartH = height - pad.top - pad.bottom;\n      const values = rows.map((row) => row.displayWeight.weight);\n      const goal = Number(state.settings.goalWeight) || 70;\n      let min = Math.min(...values, goal);\n      let max = Math.max(...values, Number(state.settings.startWeight) || 85);\n      const spread = Math.max(1, max - min);\n      min = Math.floor((min - spread * 0.14) * 10) / 10;\n      max = Math.ceil((max + spread * 0.14) * 10) / 10;\n\n      const xAt = (index) => pad.left + (rows.length === 1 ? chartW / 2 : (chartW * index) / (rows.length - 1));\n      const yAt = (value) => pad.top + ((max - value) / (max - min)) * chartH;\n\n      ctx.strokeStyle = \"#e1e7e0\";\n      ctx.fillStyle = \"#687577\";\n      ctx.font = \"12px -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif\";\n      ctx.textAlign = \"right\";\n      ctx.textBaseline = \"middle\";\n      for (let i = 0; i <= 4; i += 1) {\n        const value = min + ((max - min) * i) / 4;\n        const y = yAt(value);\n        ctx.beginPath();\n        ctx.moveTo(pad.left, y);\n        ctx.lineTo(width - pad.right, y);\n        ctx.stroke();\n        ctx.fillText(value.toFixed(1), pad.left - 8, y);\n      }\n\n      const goalY = yAt(goal);\n      ctx.strokeStyle = \"#b7781c\";\n      ctx.setLineDash([5, 5]);\n      ctx.beginPath();\n      ctx.moveTo(pad.left, goalY);\n      ctx.lineTo(width - pad.right, goalY);\n      ctx.stroke();\n      ctx.setLineDash([]);\n\n      drawLine(ctx, rows.map((row, index) => ({ x: xAt(index), y: yAt(row.displayWeight.weight) })), \"#146c78\", 3);\n      drawLine(ctx, rows.map((row, index) => ({ x: xAt(index), y: yAt(movingAverage(rows, index, 7)) })), \"rgba(50, 110, 168, 0.55)\", 2);\n\n      rows.forEach((row, index) => {\n        const x = xAt(index);\n        const y = yAt(row.displayWeight.weight);\n        ctx.fillStyle = \"#fff\";\n        ctx.strokeStyle = \"#146c78\";\n        ctx.lineWidth = 2;\n        ctx.beginPath();\n        ctx.arc(x, y, 4, 0, Math.PI * 2);\n        ctx.fill();\n        ctx.stroke();\n      });\n\n      const labels = rows.length <= 5 ? rows.map((_, index) => index) : [0, Math.floor((rows.length - 1) / 2), rows.length - 1];\n      ctx.fillStyle = \"#687577\";\n      ctx.textAlign = \"center\";\n      ctx.textBaseline = \"top\";\n      labels.forEach((index) => ctx.fillText(formatDate(rows[index].date).replace(\" \", \"\"), xAt(index), height - pad.bottom + 18));\n    }\n\n    function drawLine(ctx, points, color, width) {\n      const valid = points.filter((point) => Number.isFinite(point.y));\n      if (!valid.length) return;\n      ctx.strokeStyle = color;\n      ctx.lineWidth = width;\n      ctx.lineJoin = \"round\";\n      ctx.lineCap = \"round\";\n      ctx.beginPath();\n      valid.forEach((point, index) => {\n        if (index === 0) ctx.moveTo(point.x, point.y);\n        else ctx.lineTo(point.x, point.y);\n      });\n      ctx.stroke();\n    }\n\n    function escapeHtml(value) {\n      return String(value || \"\")\n        .replaceAll(\"&\", \"&amp;\")\n        .replaceAll(\"<\", \"&lt;\")\n        .replaceAll(\">\", \"&gt;\")\n        .replaceAll('\"', \"&quot;\")\n        .replaceAll(\"'\", \"&#039;\");\n    }\n\n    el.saveWeight.addEventListener(\"click\", () => {\n      const weight = numberOrNull(el.weight.value);\n      if (!el.weightDate.value || !weight) {\n        showToast(\"日付と体重を入力してください\");\n        return;\n      }\n      const now = new Date().toISOString();\n      const entry = {\n        id: `${el.weightDate.value}:${el.weightSlot.value}`,\n        date: el.weightDate.value,\n        slot: el.weightSlot.value,\n        weight: round(weight),\n        note: el.note.value.trim(),\n        createdAt: now,\n        updatedAt: now\n      };\n      const index = state.weights.findIndex((item) => item.id === entry.id);\n      if (index >= 0) {\n        entry.createdAt = state.weights[index].createdAt || now;\n        state.weights[index] = entry;\n      } else {\n        state.weights.push(entry);\n      }\n      state.weights.sort((a, b) => a.date.localeCompare(b.date));\n      save();\n      render();\n      showToast(\"体重を保存しました\");\n    });\n\n    el.saveSettings.addEventListener(\"click\", () => {\n      state.settings.height = Number(el.height.value) || 174;\n      state.settings.startWeight = Number(el.startWeight.value) || 85;\n      state.settings.goalWeight = Number(el.goalWeight.value) || 70;\n      state.settings.displaySlot = el.displaySlot.value || \"morning\";\n      save();\n      render();\n      showToast(\"設定を保存しました\");\n    });\n\n    el.recordTable.addEventListener(\"click\", (event) => {\n      const button = event.target.closest(\"[data-edit-date]\");\n      if (!button) return;\n      const date = button.dataset.editDate;\n      const row = dailyRows().find((item) => item.date === date);\n      if (!row) return;\n      const preferred = row[state.settings.displaySlot] || row.morning || row.evening;\n      if (!preferred) return;\n      el.weightDate.value = preferred.date;\n      el.weightSlot.value = preferred.slot;\n      el.weight.value = preferred.weight;\n      el.note.value = preferred.note || \"\";\n      el.weight.scrollIntoView({ behavior: \"smooth\", block: \"center\" });\n    });\n\n    el.weightDate.addEventListener(\"change\", () => {\n      const id = `${el.weightDate.value}:${el.weightSlot.value}`;\n      const found = state.weights.find((entry) => entry.id === id);\n      if (!found) return;\n      el.weight.value = found.weight;\n      el.note.value = found.note || \"\";\n    });\n\n    el.weightSlot.addEventListener(\"change\", () => {\n      const id = `${el.weightDate.value}:${el.weightSlot.value}`;\n      const found = state.weights.find((entry) => entry.id === id);\n      el.weight.value = found ? found.weight : \"\";\n      el.note.value = found ? found.note || \"\" : \"\";\n    });\n\n    document.querySelectorAll(\"[data-range]\").forEach((button) => {\n      button.addEventListener(\"click\", () => {\n        state.range = button.dataset.range;\n        document.querySelectorAll(\"[data-range]\").forEach((item) => item.classList.toggle(\"active\", item === button));\n        drawWeightChart();\n      });\n    });\n\n    el.saveSync.addEventListener(\"click\", () => {\n      state.sync.url = el.syncUrl.value.trim();\n      state.sync.token = el.syncToken.value.trim();\n      saveLocalOnly();\n      renderSyncStatus();\n      showToast(state.sync.url ? \"同期設定を保存しました\" : \"同期URLを解除しました\");\n    });\n\n    el.pullSync.addEventListener(\"click\", pullSync);\n    el.pushSync.addEventListener(\"click\", () => pushSync(false));\n\n    el.exportBtn.addEventListener(\"click\", () => {\n      const blob = new Blob([JSON.stringify(getAppData(), null, 2)], { type: \"application/json\" });\n      const url = URL.createObjectURL(blob);\n      const link = document.createElement(\"a\");\n      link.href = url;\n      link.download = `weight-tracker-${todayIso()}.json`;\n      link.click();\n      URL.revokeObjectURL(url);\n    });\n\n    el.importInput.addEventListener(\"change\", (event) => {\n      const file = event.target.files[0];\n      if (!file) return;\n      const reader = new FileReader();\n      reader.onload = () => {\n        try {\n          applyAppData(mergeAppData(JSON.parse(String(reader.result || \"{}\"))));\n          save();\n          showToast(\"読み込みました\");\n        } catch {\n          showToast(\"JSONを読み込めませんでした\");\n        }\n      };\n      reader.readAsText(file);\n      event.target.value = \"\";\n    });\n\n    el.clearBtn.addEventListener(\"click\", () => {\n      if (!confirm(\"すべての体重データを削除しますか？\")) return;\n      state.weights = [];\n      save();\n      render();\n      showToast(\"削除しました\");\n    });\n\n    window.addEventListener(\"resize\", drawWeightChart);\n\n    load();\n    render();\n    window.setTimeout(() => pullSync(), 800);\n  </script>\n</body>\n</html>\n";
